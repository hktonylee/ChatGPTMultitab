{
  "manifest_version": 3,
  "name": "ChatGPT Multitab System",
  "description": "Creates a multitab ChatGPT workspace with trusted frame access for configured exact URLs.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "cookies",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "extension-icon.png",
    "32": "extension-icon.png",
    "48": "extension-icon.png",
    "128": "extension-icon.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/chatgpt-url.js",
        "src/chatgpt-location.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "extension-icon.png",
      "32": "extension-icon.png",
      "48": "extension-icon.png",
      "128": "extension-icon.png"
    },
    "default_popup": "options.html",
    "default_title": "ChatGPT Multitab System"
  }
}
