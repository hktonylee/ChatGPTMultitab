{
  "manifest_version": 3,
  "name": "ChatGPT Multitab System",
  "description": "Creates a multitab ChatGPT workspace with trusted frame access for configured URL patterns.",
  "version": "0.1.0",
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "favicon.svg",
    "32": "favicon.svg",
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "favicon.svg",
      "32": "favicon.svg",
      "48": "favicon.svg",
      "128": "favicon.svg"
    },
    "default_popup": "options.html",
    "default_title": "ChatGPT Multitab System"
  }
}
